
<style>
  @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700&display=swap');
  #autism-sim-root {
    font-family: 'Tajawal', sans-serif;
    direction: rtl;
    background: #1e3a8a;
    color: #fff;
    border-radius: 16px;
    padding: 0;
    overflow: hidden;
    min-height: 520px;
    position: relative;
    user-select: none;
  }
  #sim-header {
    background: #162d6e;
    padding: 18px 24px 14px;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    display: flex;
    align-items: center;
    gap: 12px;
  }
  #sim-header .logo {
    width: 36px; height: 36px;
    background: #3b82f6;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; font-weight: 700;
  }
  #sim-header h1 { margin: 0; font-size: 18px; font-weight: 700; letter-spacing: 0.3px; }
  #sim-header p  { margin: 2px 0 0; font-size: 12px; color: rgba(255,255,255,0.55); }

  #sim-body { padding: 20px 24px; }

  .sim-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 12px;
    padding: 16px 20px;
    margin-bottom: 14px;
  }
  .sim-card h2 { margin: 0 0 4px; font-size: 14px; font-weight: 700; color: #93c5fd; }
  .sim-card p  { margin: 0 0 12px; font-size: 12px; color: rgba(255,255,255,0.6); line-height: 1.6; }

  .btn-row { display: flex; gap: 10px; flex-wrap: wrap; }
  .btn {
    padding: 9px 18px;
    border-radius: 8px;
    border: none;
    font-family: 'Tajawal', sans-serif;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: transform 0.1s, box-shadow 0.1s;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .btn:active { transform: scale(0.96); }
  .btn-primary { background: #3b82f6; color: #fff; }
  .btn-primary.active { background: #ef4444; }
  .btn-audio  { background: #1d4ed8; color: #fff; }
  .btn-audio.active { background: #b91c1c; }
  .btn-task   { background: #f59e0b; color: #1a1a1a; font-weight: 700; }

  #overlay {
    position: absolute; inset: 0;
    pointer-events: none;
    border-radius: 16px;
    z-index: 5;
    transition: backdrop-filter 0.2s;
  }
  #flicker-layer {
    position: absolute; inset: 0;
    border-radius: 16px;
    pointer-events: none;
    z-index: 6;
    background: transparent;
  }

  #task-zone {
    position: relative;
    min-height: 120px;
    background: rgba(0,0,0,0.25);
    border-radius: 10px;
    overflow: hidden;
    margin-top: 8px;
    border: 1px dashed rgba(255,255,255,0.2);
    display: flex; align-items: center; justify-content: center;
  }
  #moving-btn {
    position: absolute;
    padding: 10px 20px;
    background: #22c55e;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: 'Tajawal', sans-serif;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    z-index: 10;
    pointer-events: all;
    transition: background 0.15s;
  }
  #task-msg { font-size: 12px; color: rgba(255,255,255,0.45); text-align: center; }

  #score-bar {
    display: flex; gap: 16px; margin-top: 10px;
  }
  .score-box {
    background: rgba(255,255,255,0.08);
    border-radius: 8px;
    padding: 8px 14px;
    flex: 1;
    text-align: center;
  }
  .score-box .label { font-size: 11px; color: rgba(255,255,255,0.5); }
  .score-box .val   { font-size: 22px; font-weight: 700; color: #93c5fd; }

  #status-bar {
    margin-top: 12px;
    padding: 8px 14px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 500;
    background: rgba(59,130,246,0.15);
    color: #93c5fd;
    min-height: 34px;
    display: flex; align-items: center;
  }

  .intensity-row { display: flex; align-items: center; gap: 10px; margin-top: 8px; }
  .intensity-row label { font-size: 12px; color: rgba(255,255,255,0.6); white-space: nowrap; }
  input[type=range] { flex: 1; accent-color: #3b82f6; }
  .intensity-val { font-size: 12px; color: #93c5fd; min-width: 28px; }
</style>

<div id="autism-sim-root">
  <div id="overlay"></div>
  <div id="flicker-layer"></div>

  <div id="sim-header">
    <div class="logo">م</div>
    <div>
      <h1>محاكي التوحد ("نسخة تجريبية" لازال لايعمل بشكل فعلي) </h1>
      <p>تجربة تفاعلية للتعاطف وفهم الحمل الحسي</p>
    </div>
  </div>

  <div id="sim-body">

    <div class="sim-card">
      <h2>التأثير البصري — الحمل الحسي</h2>
      <p>يُشعر كثير من ذوي التوحد بأن الضوء والحركة تتضخّم وتُشتّت التركيز. اضغط لتفعيل التأثير.</p>
      <div class="intensity-row">
        <label>شدة التشويش</label>
        <input type="range" id="blur-level" min="1" max="5" value="2" step="1">
        <span class="intensity-val" id="blur-val">2</span>
      </div>
      <div class="btn-row" style="margin-top:12px;">
        <button class="btn btn-primary" id="btn-visual">تفعيل التشتت البصري</button>
      </div>
    </div>

    <div class="sim-card">
      <h2>التأثير السمعي — الضجيج الحسي</h2>
      <p>الأصوات المتداخلة تُصعّب التركيز. الضجيج الأبيض مع نبضات متكررة يُحاكي البيئة الصاخبة.</p>
      <div class="btn-row">
        <button class="btn btn-audio" id="btn-audio">تشغيل الضجيج السمعي</button>
      </div>
    </div>

    <div class="sim-card">
      <h2>المهمة التفاعلية — اختبر التركيز</h2>
      <p>حاول الضغط على الزر الأخضر المتحرك خلال 20 ثانية. لاحظ مدى صعوبة ذلك وسط التشويش الحسي!</p>
      <div id="task-zone">
        <span id="task-msg">اضغط "ابدأ المهمة" للبدء</span>
        <button id="moving-btn" style="display:none;">اضغطني!</button>
      </div>
      <div id="score-bar">
        <div class="score-box"><div class="label">النجاحات</div><div class="val" id="hits">0</div></div>
        <div class="score-box"><div class="label">الوقت المتبقي</div><div class="val" id="timer">—</div></div>
        <div class="score-box"><div class="label">الإخفاقات</div><div class="val" id="misses">0</div></div>
      </div>
      <div class="btn-row" style="margin-top:10px;">
        <button class="btn btn-task" id="btn-task">ابدأ المهمة</button>
      </div>
      <div id="status-bar">جاهز للتجربة — فعّل التأثيرات أولاً لتجربة كاملة.</div>
    </div>

  </div>
</div>

<script>
(function(){
  const root    = document.getElementById('autism-sim-root');
  const overlay = document.getElementById('overlay');
  const flicker = document.getElementById('flicker-layer');
  const btnVis  = document.getElementById('btn-visual');
  const btnAud  = document.getElementById('btn-audio');
  const btnTask = document.getElementById('btn-task');
  const movBtn  = document.getElementById('moving-btn');
  const taskZone= document.getElementById('task-zone');
  const taskMsg = document.getElementById('task-msg');
  const hitsEl  = document.getElementById('hits');
  const timerEl = document.getElementById('timer');
  const missesEl= document.getElementById('misses');
  const statusEl= document.getElementById('status-bar');
  const blurSlider = document.getElementById('blur-level');
  const blurVal    = document.getElementById('blur-val');

  let visualOn = false, audioOn = false;
  let shakeInterval, flickerInterval, moveInterval, countdownInterval;
  let audioCtx = null, noiseNode = null, gainNode = null, pulseInterval;
  let hits = 0, misses = 0, taskRunning = false, taskSecs = 20;
  let blurLevel = 2;
  let mouseMoveBlur = 0, lastMouseX = 0, lastMouseY = 0;

  blurSlider.addEventListener('input', () => {
    blurLevel = parseInt(blurSlider.value);
    blurVal.textContent = blurLevel;
  });

  function applyBlur(extra) {
    const b = Math.min(12, blurLevel * 1.5 + extra);
    overlay.style.backdropFilter = `blur(${b.toFixed(1)}px)`;
    overlay.style.webkitBackdropFilter = `blur(${b.toFixed(1)}px)`;
  }

  root.addEventListener('mousemove', (e) => {
    if (!visualOn) return;
    const dx = e.clientX - lastMouseX;
    const dy = e.clientY - lastMouseY;
    lastMouseX = e.clientX; lastMouseY = e.clientY;
    const speed = Math.sqrt(dx*dx + dy*dy);
    mouseMoveBlur = Math.min(8, speed * 0.18);
    applyBlur(mouseMoveBlur);
    setTimeout(() => { mouseMoveBlur = Math.max(0, mouseMoveBlur - 1); applyBlur(mouseMoveBlur); }, 300);
  });

  function startShake() {
    shakeInterval = setInterval(() => {
      const x = (Math.random()-0.5)*6;
      const y = (Math.random()-0.5)*4;
      const r = (Math.random()-0.5)*1.5;
      root.style.transform = `translate(${x}px,${y}px) rotate(${r}deg)`;
      setTimeout(()=>{ root.style.transform = ''; }, 60);
    }, 180);
  }

  function stopShake() {
    clearInterval(shakeInterval);
    root.style.transform = '';
  }

  function startFlicker() {
    let fl = false;
    flickerInterval = setInterval(() => {
      fl = !fl;
      flicker.style.background = fl ? 'rgba(255,255,255,0.04)' : 'transparent';
    }, 120 + Math.random()*180);
  }

  function stopFlicker() {
    clearInterval(flickerInterval);
    flicker.style.background = 'transparent';
  }

  btnVis.addEventListener('click', () => {
    visualOn = !visualOn;
    if (visualOn) {
      applyBlur(0);
      startShake();
      startFlicker();
      btnVis.textContent = 'إيقاف التشتت البصري';
      btnVis.classList.add('active');
      statusEl.textContent = 'التشتت البصري مُفعَّل — حرّك الفأرة بسرعة لزيادة التشويش.';
      statusEl.style.color = '#fca5a5';
    } else {
      overlay.style.backdropFilter = 'none';
      overlay.style.webkitBackdropFilter = 'none';
      stopShake(); stopFlicker();
      btnVis.textContent = 'تفعيل التشتت البصري';
      btnVis.classList.remove('active');
      statusEl.textContent = 'التأثير البصري متوقف.';
      statusEl.style.color = '#93c5fd';
    }
  });

  function createNoise() {
    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    const bufferSize = audioCtx.sampleRate * 2;
    const buf = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
    const data = buf.getChannelData(0);
    for (let i = 0; i < bufferSize; i++) data[i] = Math.random()*2 - 1;
    const src = audioCtx.createBufferSource();
    src.buffer = buf;
    src.loop = true;
    gainNode = audioCtx.createGain();
    gainNode.gain.value = 0.08;
    src.connect(gainNode);
    gainNode.connect(audioCtx.destination);
    src.start();
    noiseNode = src;
    return gainNode;
  }

  function startPulse() {
    let up = true;
    pulseInterval = setInterval(() => {
      if (!gainNode) return;
      gainNode.gain.value = up ? 0.14 : 0.05;
      up = !up;
    }, 400 + Math.random()*300);
  }

  function stopAudio() {
    if (noiseNode) { try { noiseNode.stop(); } catch(e){} noiseNode = null; }
    if (gainNode)  { gainNode = null; }
    clearInterval(pulseInterval);
  }

  btnAud.addEventListener('click', () => {
    audioOn = !audioOn;
    if (audioOn) {
      createNoise(); startPulse();
      btnAud.textContent = 'إيقاف الضجيج السمعي';
      btnAud.classList.add('active');
      statusEl.textContent = 'الضجيج السمعي شُغِّل — أغمض عينيك وحاول التركيز.';
      statusEl.style.color = '#fca5a5';
    } else {
      stopAudio();
      btnAud.textContent = 'تشغيل الضجيج السمعي';
      btnAud.classList.remove('active');
      statusEl.textContent = 'الضجيج السمعي متوقف.';
      statusEl.style.color = '#93c5fd';
    }
  });

  function randomPos() {
    const zRect = taskZone.getBoundingClientRect();
    const bw = 100, bh = 40;
    const maxX = Math.max(0, taskZone.clientWidth - bw - 10);
    const maxY = Math.max(0, taskZone.clientHeight - bh - 10);
    return {
      x: 8 + Math.random() * maxX,
      y: 8 + Math.random() * maxY
    };
  }

  function moveButton() {
    const p = randomPos();
    movBtn.style.left = p.x + 'px';
    movBtn.style.top  = p.y + 'px';
  }

  function endTask(reason) {
    taskRunning = false;
    clearInterval(moveInterval);
    clearInterval(countdownInterval);
    movBtn.style.display = 'none';
    taskMsg.style.display = 'flex';
    btnTask.style.display = 'inline-flex';
    const rate = hits + misses > 0 ? Math.round(hits/(hits+misses)*100) : 0;
    if (reason === 'done') {
      taskMsg.textContent = `انتهت المهمة! ✓ نجاح ${hits} مرة — معدل الدقة: ${rate}%`;
      statusEl.textContent = `هكذا يشعر كثيرون بالتوحد يومياً — الحمل الحسي يجعل أبسط المهام شبه مستحيلة.`;
      statusEl.style.color = '#86efac';
    }
    timerEl.textContent = '0';
  }

  movBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    if (!taskRunning) return;
    hits++;
    hitsEl.textContent = hits;
    statusEl.textContent = 'أحسنت! حاول مرة أخرى...';
    moveButton();
  });

  taskZone.addEventListener('click', (e) => {
    if (!taskRunning || e.target === movBtn) return;
    misses++;
    missesEl.textContent = misses;
  });

  btnTask.addEventListener('click', () => {
    hits = 0; misses = 0; taskSecs = 20;
    hitsEl.textContent = '0';
    missesEl.textContent = '0';
    timerEl.textContent = '20';
    taskMsg.style.display = 'none';
    movBtn.style.display = 'block';
    btnTask.style.display = 'none';
    taskRunning = true;

    const speed = visualOn ? 900 : 1500;
    moveButton();
    moveInterval = setInterval(() => { if(taskRunning) moveButton(); }, speed);

    countdownInterval = setInterval(() => {
      taskSecs--;
      timerEl.textContent = taskSecs;
      if (taskSecs <= 0) endTask('done');
    }, 1000);

    statusEl.textContent = 'اضغط على الزر الأخضر! — الوقت يداهمك...';
    statusEl.style.color = '#fcd34d';
  });

})();
</script>
